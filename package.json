{
  "name": "invoice-ninja-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Invoice Ninja - create invoices, manage clients, payments, quotes, and expenses",
  "type": "module",
  "main": "dist/index.js",
  "bin": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && shx chmod +x dist/index.js",
